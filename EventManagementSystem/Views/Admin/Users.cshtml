@model IEnumerable<UserRowViewModel>
@{
    ViewData["Title"] = "Потребители";
}

<h1 class="mb-3">Потребители</h1>

<table class="table align-middle">
    <thead>
        <tr>
            <th>Име</th>
            <th>Имейл</th>
            <th>Роли</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var u in Model)
        {
            <tr>
                <td>@u.FullName</td>
                <td>@u.Email</td>
                <td>
                    @foreach (var role in u.Roles)
                    {
                        <span class="badge bg-info text-dark">@role</span>
                    }
                </td>
                <td>
                    @if (!u.Roles.Contains("Organizer") && !u.Roles.Contains("Admin"))
                    {
                        <form asp-action="MakeOrganizer" asp-route-id="@u.Id" method="post">
                            <button type="submit" class="btn btn-sm btn-outline-success">Направи организатор</button>
                        </form>
                    }
                    else
                    {
                        <span class="text-muted">—</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
