@model IEnumerable<Category>
@{
    ViewData["Title"] = "Категории";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Категории</h1>
    <a class="btn btn-success" asp-action="Create">+ Нова категория</a>
</div>

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>Име</th>
            <th>Описание</th>
            <th>Брой събития</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.Name</td>
                <td>@c.Description</td>
                <td>@c.Events.Count</td>
                <td>
                    <a class="btn btn-sm btn-outline-warning" asp-action="Edit" asp-route-id="@c.Id">Редактирай</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@c.Id">Изтрий</a>
                </td>
            </tr>
        }
    </tbody>
</table>
